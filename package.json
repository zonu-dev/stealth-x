{
  "name": "stealth-x",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "A Chrome extension that locally masks identifying X account information.",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "dev": "node ./scripts/build.mjs --watch",
    "check": "tsc --noEmit",
    "test": "vitest run --environment jsdom"
  },
  "keywords": [
    "chrome-extension",
    "manifest-v3",
    "x",
    "twitter",
    "privacy"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/chrome": "^0.1.29",
    "@types/jsdom": "^21.1.7",
    "esbuild": "^0.25.4",
    "jsdom": "^26.1.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
